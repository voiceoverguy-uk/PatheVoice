{
  "installCommand": "npm install",
  "buildCommand": "npm run build && npx playwright install chromium --with-deps && node prerender.mjs",
  "redirects": [
    { "source": "/guy-harris", "destination": "https://www.pathevoice.co.uk/", "permanent": true },
    { "source": "/guy-harris/", "destination": "https://www.pathevoice.co.uk/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
